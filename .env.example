# ============================================
# 数据库类型（必需，以下任选其一）
# oracle, mysql, postgresql, sqlserver, sqlite
# ============================================
DB_TYPE=oracle

# ============================================
# Oracle 连接配置（DB_TYPE=oracle 时使用）
# ============================================
DB_ORACLE_USER=scott
DB_ORACLE_PASSWORD=tiger
DB_ORACLE_CONNECT_STRING=localhost:1521/ORCL

# Oracle Instant Client 路径（可选，不添加到系统 PATH 时使用）
# DB_ORACLE_CLIENT_PATH=C:\oracle\instantclient_19_22

# ============================================
# MySQL 连接配置（DB_TYPE=mysql 时使用）
# ============================================
# DB_MYSQL_HOST=localhost
# DB_MYSQL_PORT=3306
# DB_MYSQL_USER=root
# DB_MYSQL_PASSWORD=password
# DB_MYSQL_DATABASE=mydb

# ============================================
# PostgreSQL 连接配置（DB_TYPE=postgresql 时使用）
# ============================================
# DB_POSTGRESQL_HOST=localhost
# DB_POSTGRESQL_PORT=5432
# DB_POSTGRESQL_USER=postgres
# DB_POSTGRESQL_PASSWORD=password
# DB_POSTGRESQL_DATABASE=mydb

# ============================================
# SQL Server 连接配置（DB_TYPE=sqlserver 时使用）
# ============================================
# DB_SQLSERVER_HOST=localhost
# DB_SQLSERVER_PORT=1433
# DB_SQLSERVER_USER=sa
# DB_SQLSERVER_PASSWORD=password
# DB_SQLSERVER_DATABASE=mydb

# ============================================
# SQLite 连接配置（DB_TYPE=sqlite 时使用）
# ============================================
# DB_SQLITE_DATABASE=/path/to/database.db

# ============================================
# 安全配置（默认全部 false，只读模式）
# 支持独立权限控制，按需开启
# ============================================
DB_ORACLE_ALLOW_INSERT=false
DB_ORACLE_ALLOW_UPDATE=false
DB_ORACLE_ALLOW_DELETE=false
DB_ORACLE_ALLOW_DDL=false
DB_ORACLE_ALLOW_PROCEDURE=false
DB_ORACLE_ALLOW_TRANSACTION=false
DB_ORACLE_ALLOW_BATCH=false

# 其他数据库权限配置示例（MySQL）
# DB_MYSQL_ALLOW_INSERT=false
# DB_MYSQL_ALLOW_UPDATE=false
# DB_MYSQL_ALLOW_DELETE=false
# DB_MYSQL_ALLOW_DDL=false
# DB_MYSQL_ALLOW_PROCEDURE=false
# DB_MYSQL_ALLOW_TRANSACTION=false
# DB_MYSQL_ALLOW_BATCH=false
