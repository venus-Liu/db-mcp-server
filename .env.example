# ============================================
# 数据库类型（必需）
# oracle, mysql, postgresql, sqlserver, sqlite
# ============================================
DB_TYPE=oracle

# ============================================
# 连接配置（通用，通过 DB_TYPE 区分数据库类型）
# ============================================
DB_USER=scott
DB_PASSWORD=tiger
DB_CONNECT_STRING=localhost:1521/ORCL

# Oracle Instant Client 路径（可选，仅 Oracle 需要）
# DB_CLIENT_PATH=C:\oracle\instantclient_19_22

# 连接池配置（仅 Oracle 需要）
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_POOL_INCREMENT=1

# MySQL / PostgreSQL / SQL Server 主机和端口
# DB_HOST=localhost
# DB_PORT=3306

# 数据库名（MySQL / PostgreSQL / SQL Server / SQLite 需要）
# DB_DATABASE=mydb

# ============================================
# 安全配置（默认全部 false，只读模式）
# ============================================
DB_ALLOW_INSERT=false
DB_ALLOW_UPDATE=false
DB_ALLOW_DELETE=false
DB_ALLOW_DDL=false
DB_ALLOW_PROCEDURE=false
DB_ALLOW_TRANSACTION=false
DB_ALLOW_BATCH=false
