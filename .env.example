# Oracle 数据库连接配置

# 数据库用户名
ORACLE_USER=your_username

# 数据库密码
ORACLE_PASSWORD=your_password

# 连接字符串，格式: hostname:port/service_name
# 示例: localhost:1521/ORCL
ORACLE_CONNECT_STRING=localhost:1521/ORCL

# 连接池配置（可选）
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# 安全配置（可选，默认全部 false，即只读模式）
# 是否允许 INSERT 操作
ORACLE_ALLOW_INSERT=false
# 是否允许 UPDATE 操作
ORACLE_ALLOW_UPDATE=false
# 是否允许 DELETE 操作
ORACLE_ALLOW_DELETE=false

# Oracle Instant Client 路径（可选，不添加到系统 PATH 时使用）
# ORACLE_CLIENT_PATH=C:\oracle\instantclient_19_22
